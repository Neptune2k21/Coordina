FROM mcr.microsoft.com/dotnet/sdk:9.0

WORKDIR /workspace

COPY Coordina.sln Directory.Build.props ./
COPY src/api/Coordina.Api.csproj src/api/
COPY tests/api/Coordina.Api.Tests.csproj tests/api/

RUN dotnet restore Coordina.sln -m:1

COPY . .

ENV ASPNETCORE_URLS=http://+:5050
EXPOSE 5050

CMD ["dotnet", "watch", "--project", "src/api/Coordina.Api.csproj", "--urls", "http://+:5050"]
